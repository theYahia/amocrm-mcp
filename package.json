{
  "name": "@theyahia/amocrm-mcp",
  "version": "2.0.0",
  "description": "Production-grade MCP server for amoCRM API — 19 tools: leads, contacts, companies, pipelines, tasks, notes, search, events, unsorted. OAuth 2.0 with auto token refresh.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "amocrm-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "smithery.yaml"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.theYahia/amocrm-mcp",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "modelcontextprotocol",
    "claude",
    "ai",
    "llm",
    "anthropic",
    "cursor",
    "ai-tools",
    "ai-agent",
    "russian-api",
    "amocrm",
    "crm",
    "leads",
    "contacts",
    "sales",
    "companies",
    "pipelines",
    "tasks",
    "events",
    "oauth",
    "smithery"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theYahia/amocrm-mcp.git"
  },
  "homepage": "https://github.com/theYahia/amocrm-mcp#readme",
  "author": "theYahia (https://github.com/theYahia)"
}
